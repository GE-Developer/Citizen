    "Question.100.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "რას ნიშნავს უდანაშაულობის პრეზუმფცია?"
          }
        }
      }
    },
    "Question.100.v1" : {
      "extractionState" : "manual",
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ადამიანი უდანაშაულოდ ითვლება, ვიდრე სასამართლო გადაწყვეტილება არ გამოცხადდება"
          }
        }
      }
    },
    "Question.100.v2" : {
      "extractionState" : "manual",
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ადამიანი უდანაშაულოდ ითვლება, ვიდრე მისი დამნაშავეობა არ დამტკიცდება მედიაში გავრცელებული ინფორმაციით"
          }
        }
      }
    },
    "Question.100.v3" : {
      "extractionState" : "manual",
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ადამიანი უდანაშაულოდ ითვლება, ვიდრე მისი დამნაშავეობა არ დამტკიცდება კანონით დადგენილი წესით, კანონიერ ძალაში შესული სასამართლოს გამამტყუნებელი განაჩენით"
          }
        }
      }
    },
    "Question.100.v4" : {
      "extractionState" : "manual",
      "localizations" : {
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ადამიანი უდანაშაულოდ ითვლება, ვიდრე გამოძიება დაიწყება ადამიანი უდანაშაულოდ ითვლება, ვიდრე გამოძიება დაიწყება  ადამიანი უდანაშაულოდ ითვლება, ვიდრე გამოძიება დაიწყება  ადამიანი უდანაშაულოდ ითვლება, ვიდრე გამოძიება დაიწყება ადამიანი უდანაშაულოდ ითვლება, ვიდრე გამოძიება დაიწყება "
          }
