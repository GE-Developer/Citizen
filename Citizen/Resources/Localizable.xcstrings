    "PayWall.subscriptionDisclaimer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Subscriptions auto-renew until canceled in your App Store account settings at least 24 hours before the end of the current period. Payment is charged to your Apple ID at confirmation of purchase."
          }
        },
        "ka" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "გამოწერა ავტომატურად განახლდება, სანამ არ გააუქმებთ მას App Store-ის ანგარიშის პარამეტრებში მიმდინარე პერიოდის დასრულებამდე მინიმუმ 24 საათით ადრე. გადახდა ჩამოიჭრება თქვენი Apple ID-დან შესყიდვის დადასტურებისას."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подписки продлеваются автоматически до их отмены в настройках учётной записи App Store не менее чем за 24 часа до окончания текущего периода. Оплата списывается с вашего Apple ID при подтверждении покупки."
          }
        }
      }
    },
